# Copy file ini jadi ".env.local" lalu isi value di bawah dengan Measurement
# ID dari Google Analytics 4 kamu (format: G-XXXXXXXXXX).
# Cara mendapatkannya: lihat PANDUAN-ANALYTICS.md bagian "Opsi Gratis:
# Google Analytics 4".
#
# Kalau dikosongkan / file .env.local tidak dibuat, website tetap berjalan
# normal — hanya saja tracking GA4 tidak aktif.

NEXT_PUBLIC_GA_ID=
